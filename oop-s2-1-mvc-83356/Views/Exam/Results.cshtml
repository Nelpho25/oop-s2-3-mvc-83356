@model Exam
@{
    ViewData["Title"] = "Exam Results - " + Model.Title;
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">@Model.Title</h1>
            <p class="text-muted">@Model.Course?.Name</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Exam Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <p><strong>Exam Date:</strong></p>
                            <p>@(Model.ExamDate?.ToString("MMM dd, yyyy") ?? "N/A")</p>
                        </div>
                        <div class="col-md-4">
                            <p><strong>Max Score:</strong></p>
                            <p>@Model.MaxScore</p>
                        </div>
                        <div class="col-md-4">
                            <p><strong>Results Status:</strong></p>
                            <p>
                                @if (Model.ResultsReleased)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Released</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-lock"></i> Hidden</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            @if (!Model.ExamResults.Any())
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i> No results submitted yet.
                </div>
            }
            else
            {
                <div class="card">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Student</th>
                                    <th class="text-center">Score</th>
                                    <th class="text-center">Percentage</th>
                                    <th class="text-center">Grade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in Model.ExamResults.OrderBy(er => er.StudentProfile.LastName).ThenBy(er => er.StudentProfile.FirstName))
                                {
                                    <tr>
                                        <td>
                                            <strong>@result.StudentProfile?.FirstName @result.StudentProfile?.LastName</strong>
                                            <br />
                                            <small class="text-muted">@result.StudentProfile?.StudentNumber</small>
                                        </td>
                                        <td class="text-center">
                                            @if (result.Score.HasValue)
                                            {
                                                <strong>@result.Score / @Model.MaxScore</strong>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not submitted</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (result.Score.HasValue)
                                            {
                                                var percentage = (result.Score.Value / Model.MaxScore) * 100;
                                                var badgeClass = percentage >= 80 ? "bg-success" : percentage >= 70 ? "bg-warning" : "bg-danger";
                                                <span class="badge @badgeClass">@percentage.ToString("F0")%</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">N/A</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (!string.IsNullOrEmpty(result.Grade))
                                            {
                                                <strong>@result.Grade</strong>
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

