@{
    ViewData["Title"] = "Home - VGC College Management System";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 3rem 0;
        margin: -1rem 0 2rem 0;
        border-radius: 8px;
    }
    .feature-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
    }
    .quick-access {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
    }
    .quick-access-btn {
        padding: 1rem;
        text-align: center;
        border-radius: 8px;
        text-decoration: none;
        color: white;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    .quick-access-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.2);
    }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <div class="container-fluid">
        <h1 class="display-4 fw-bold mb-3">🎓 Welcome to VGC College</h1>
        <p class="lead">Complete Student & Course Management System</p>
        <p>Manage enrollments, track attendance, grade assignments and exams, and maintain faculty assignments across all your campuses.</p>
    </div>
</div>

<div class="container-fluid">
    @if (!(User.Identity?.IsAuthenticated ?? false))
    {
        <!-- Unauthenticated User View -->
        <div class="row mb-4">
            <div class="col-md-8">
                <h2 class="mb-4">Get Started</h2>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="card feature-card h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-box-arrow-in-right" style="font-size: 3rem; color: #0066cc;"></i>
                                <h5 class="card-title mt-3">Already a Member?</h5>
                                <p class="card-text">Login to access your account and manage your courses.</p>
                                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="card feature-card h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-person-plus" style="font-size: 3rem; color: #28a745;"></i>
                                <h5 class="card-title mt-3">New Student?</h5>
                                <p class="card-text">Create a new account to enroll in courses and track your progress.</p>
                                <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg">
                                    <i class="bi bi-person-plus"></i> Register
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card bg-light feature-card">
                    <div class="card-body">
                        <h5 class="card-title">✨ Key Features</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Multi-branch management</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Student enrollment tracking</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Attendance recording</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Assignment grading</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Exam result management</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Faculty assignment</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Role-based access control</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Authenticated User View -->
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> 
            <strong>Welcome back, @User.Identity?.Name!</strong> 
            Use the navigation menu or quick access links below to get started.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>

        <!-- Quick Access Section -->
        @if (User.IsInRole("Admin"))
        {
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-shield-lock"></i> Admin Quick Access</h5>
                </div>
                <div class="card-body">
                    <div class="quick-access">
                        <a href="/Admin" class="quick-access-btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                            <i class="bi bi-speedometer2" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Dashboard</div>
                        </a>
                        <a href="/Admin/Branches" class="quick-access-btn" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                            <i class="bi bi-building" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Branches</div>
                        </a>
                        <a href="/Admin/Courses" class="quick-access-btn" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                            <i class="bi bi-book" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Courses</div>
                        </a>
                        <a href="/Admin/Students" class="quick-access-btn" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                            <i class="bi bi-people" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Students</div>
                        </a>
                        <a href="/Admin/Enrolments" class="quick-access-btn" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                            <i class="bi bi-file-earmark-check" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Enrollments</div>
                        </a>
                        <a href="/Gradebook/Courses" class="quick-access-btn" style="background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);">
                            <i class="bi bi-graph-up" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Gradebook</div>
                        </a>
                    </div>
                </div>
            </div>
        }
        else if (User.IsInRole("Faculty"))
        {
            <div class="card mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-book"></i> Faculty Quick Access</h5>
                </div>
                <div class="card-body">
                    <div class="quick-access">
                        <a href="/Faculty" class="quick-access-btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                            <i class="bi bi-speedometer2" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Dashboard</div>
                        </a>
                        <a href="/Gradebook/Courses" class="quick-access-btn" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                            <i class="bi bi-graph-up" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Gradebook</div>
                        </a>
                        <a href="/Attendance/Course/1" class="quick-access-btn" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                            <i class="bi bi-calendar-check" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Attendance</div>
                        </a>
                        <a href="/Admin/Exams" class="quick-access-btn" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                            <i class="bi bi-file-earmark-text" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Exams</div>
                        </a>
                    </div>
                </div>
            </div>
        }
        else if (User.IsInRole("Student"))
        {
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-mortarboard"></i> Student Quick Access</h5>
                </div>
                <div class="card-body">
                    <div class="quick-access">
                        <a href="/Student/Dashboard" class="quick-access-btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                            <i class="bi bi-speedometer2" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Dashboard</div>
                        </a>
                        <a href="/Student/Grades" class="quick-access-btn" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                            <i class="bi bi-graph-up" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">My Grades</div>
                        </a>
                        <a href="/Student/Attendance" class="quick-access-btn" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                            <i class="bi bi-calendar-check" style="font-size: 1.5rem;"></i>
                            <div class="mt-2">Attendance</div>
                        </a>
                    </div>
                </div>
            </div>
        }

        <!-- Features Overview -->
        <div class="row mt-4">
            <div class="col-md-12">
                <h4 class="mb-3">📋 System Features</h4>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card feature-card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-building text-primary"></i> Multi-Branch Management</h5>
                        <p class="card-text">Manage multiple campus locations with centralized control and reporting.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card feature-card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-people text-success"></i> Student Enrollment</h5>
                        <p class="card-text">Track student enrollments across courses with real-time status updates.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card feature-card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-calendar-check text-info"></i> Attendance Tracking</h5>
                        <p class="card-text">Record and monitor student attendance with automated calculations.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card feature-card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-graph-up text-warning"></i> Grade Management</h5>
                        <p class="card-text">Manage assignments, exams, and grades with automatic calculations.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card feature-card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-file-earmark-text text-danger"></i> Exam Management</h5>
                        <p class="card-text">Organize exams, release results, and manage exam scheduling.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card feature-card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-shield-lock text-secondary"></i> Role-Based Access</h5>
                        <p class="card-text">Secure system with Admin, Faculty, and Student role-based permissions.</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Footer Info -->
    <div class="alert alert-light border mt-4">
        <p class="mb-0 text-muted">
            <i class="bi bi-info-circle"></i> 
            <strong>Need help?</strong> Contact the system administrator for support.
            © 2024 VGC College Management System. All rights reserved.
        </p>
    </div>
</div>
