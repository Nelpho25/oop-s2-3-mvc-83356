@{
    ViewData["Title"] = "Home - VGC College Management System";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 3rem 1.5rem;
        margin: -1rem 0 2rem 0;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    .hero-section h1 {
        font-size: 2.5rem;
        font-weight: 700;
    }
    .hero-section p {
        font-size: 1.1rem;
        opacity: 0.95;
    }
    .feature-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid #e0e0e0;
        height: 100%;
    }
    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
    }
    .quick-access {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
    }
    .quick-access-btn {
        padding: 1.2rem;
        text-align: center;
        border-radius: 8px;
        text-decoration: none;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 120px;
    }
    .quick-access-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.2);
        text-decoration: none;
        color: white;
    }
    .quick-access-btn i {
        display: block;
        margin-bottom: 0.5rem;
    }
    .auth-container {
        animation: fadeInAnimation 0.5s ease-in;
    }
</style>

<script>
    // CSS animation for fade-in
    const style = document.createElement('style');
    style.textContent = `
        @@keyframes fadeInAnimation {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    `;
    document.head.appendChild(style);
</script>

<!-- Hero Section -->
@if (!(User.Identity?.IsAuthenticated ?? false))
{
    <div class="hero-section">
        <div class="container-fluid">
            <h1 class="fw-bold mb-3">🎓 Welcome to VGC College</h1>
            <p class="lead mb-2">Complete Student & Course Management System</p>
            <p class="mb-0">Manage enrollments, track attendance, grade assignments and exams, and maintain faculty assignments across all your campuses.</p>
        </div>
    </div>
}
else
{
    <div class="hero-section">
        <div class="container-fluid">
            <h1 class="fw-bold mb-1">Welcome back! 👋</h1>
            <p class="lead mb-0">@User.Identity?.Name</p>
        </div>
    </div>
}

<div class="container-fluid">
    @if (!(User.Identity?.IsAuthenticated ?? false))
    {
        <!-- Unauthenticated User View -->
        <div class="row mb-4">
            <div class="col-lg-8">
                <h2 class="mb-4 fw-bold">Get Started</h2>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card feature-card h-100 shadow-sm">
                            <div class="card-body text-center p-4">
                                <div style="font-size: 3rem; color: #0066cc;" class="mb-3">
                                    <i class="bi bi-box-arrow-in-right"></i>
                                </div>
                                <h5 class="card-title fw-bold">Already a Member?</h5>
                                <p class="card-text mb-4">Login to access your account and manage your courses.</p>
                                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card feature-card h-100 shadow-sm">
                            <div class="card-body text-center p-4">
                                <div style="font-size: 3rem; color: #28a745;" class="mb-3">
                                    <i class="bi bi-person-plus"></i>
                                </div>
                                <h5 class="card-title fw-bold">New Student?</h5>
                                <p class="card-text mb-4">Create a new account to enroll in courses and track your progress.</p>
                                <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg">
                                    <i class="bi bi-person-plus"></i> Register
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card bg-light feature-card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3">✨ Key Features</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Multi-branch management</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Student enrollment tracking</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Attendance recording</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Assignment grading</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Exam result management</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Faculty assignment</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Role-based access control</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Authenticated User View -->
        <div class="auth-container">
            <!-- Quick Access Section -->
            @if (User.IsInRole("Admin"))
            {
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-primary text-white fw-bold">
                        <i class="bi bi-shield-lock"></i> Admin Quick Access
                    </div>
                    <div class="card-body">
                        <div class="quick-access">
                            <a href="/Admin" class="quick-access-btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <i class="bi bi-speedometer2" style="font-size: 1.5rem;"></i>
                                <span>Dashboard</span>
                            </a>
                            <a href="/Admin/Branches" class="quick-access-btn" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                                <i class="bi bi-building" style="font-size: 1.5rem;"></i>
                                <span>Branches</span>
                            </a>
                            <a href="/Admin/Courses" class="quick-access-btn" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                                <i class="bi bi-book" style="font-size: 1.5rem;"></i>
                                <span>Courses</span>
                            </a>
                            <a href="/Admin/Students" class="quick-access-btn" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                                <i class="bi bi-people" style="font-size: 1.5rem;"></i>
                                <span>Students</span>
                            </a>
                            <a href="/Admin/Enrolments" class="quick-access-btn" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                                <i class="bi bi-file-earmark-check" style="font-size: 1.5rem;"></i>
                                <span>Enrollments</span>
                            </a>
                            <a href="/Gradebook/Courses" class="quick-access-btn" style="background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);">
                                <i class="bi bi-graph-up" style="font-size: 1.5rem;"></i>
                                <span>Gradebook</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
            else if (User.IsInRole("Faculty"))
            {
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-info text-white fw-bold">
                        <i class="bi bi-person-badge"></i> Faculty Dashboard
                    </div>
                    <div class="card-body">
                        <div class="quick-access">
                            <a href="/Faculty" class="quick-access-btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <i class="bi bi-speedometer2" style="font-size: 1.5rem;"></i>
                                <span>Dashboard</span>
                            </a>
                            <a href="/Gradebook/Courses" class="quick-access-btn" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                                <i class="bi bi-graph-up" style="font-size: 1.5rem;"></i>
                                <span>Gradebook</span>
                            </a>
                            <a href="/Attendance/Index" class="quick-access-btn" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                                <i class="bi bi-calendar-check" style="font-size: 1.5rem;"></i>
                                <span>Attendance</span>
                            </a>
                            <a href="/Exam" class="quick-access-btn" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                                <i class="bi bi-file-earmark-text" style="font-size: 1.5rem;"></i>
                                <span>Exams</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
            else if (User.IsInRole("Student"))
            {
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-success text-white fw-bold">
                        <i class="bi bi-mortarboard"></i> Student Dashboard
                    </div>
                    <div class="card-body">
                        <div class="quick-access">
                            <a href="/StudentDashboard" class="quick-access-btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <i class="bi bi-speedometer2" style="font-size: 1.5rem;"></i>
                                <span>Dashboard</span>
                            </a>
                            <a href="/StudentDashboard/Grades" class="quick-access-btn" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                                <i class="bi bi-graph-up" style="font-size: 1.5rem;"></i>
                                <span>My Grades</span>
                            </a>
                            <a href="/StudentDashboard/Attendance" class="quick-access-btn" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                                <i class="bi bi-calendar-check" style="font-size: 1.5rem;"></i>
                                <span>Attendance</span>
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- Features Overview -->
            <div class="row mt-5">
                <div class="col-md-12 mb-4">
                    <h4 class="fw-bold">📋 System Features</h4>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card feature-card h-100 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold text-primary mb-3">
                                <i class="bi bi-building"></i> Multi-Branch Management
                            </h6>
                            <p class="card-text">Manage multiple campus locations with centralized control and reporting.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card feature-card h-100 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold text-success mb-3">
                                <i class="bi bi-people"></i> Student Enrollment
                            </h6>
                            <p class="card-text">Track student enrollments across courses with real-time status updates.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card feature-card h-100 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold text-info mb-3">
                                <i class="bi bi-calendar-check"></i> Attendance Tracking
                            </h6>
                            <p class="card-text">Record and monitor student attendance with automated calculations.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card feature-card h-100 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold text-warning mb-3">
                                <i class="bi bi-graph-up"></i> Grade Management
                            </h6>
                            <p class="card-text">Manage assignments, exams, and grades with automatic calculations.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card feature-card h-100 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold text-danger mb-3">
                                <i class="bi bi-file-earmark-text"></i> Exam Management
                            </h6>
                            <p class="card-text">Organize exams, release results, and manage exam scheduling.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card feature-card h-100 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold text-secondary mb-3">
                                <i class="bi bi-shield-lock"></i> Role-Based Access
                            </h6>
                            <p class="card-text">Secure system with Admin, Faculty, and Student role-based permissions.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Footer Info -->
    <div class="alert alert-light border-top mt-5 mb-0">
        <p class="mb-0 text-muted text-center">
            <i class="bi bi-info-circle"></i> 
            <strong>Need help?</strong> Contact the system administrator for support.
        </p>
        <p class="mb-0 text-muted text-center small mt-2">
            © 2024 VGC College Management System. All rights reserved.
        </p>
    </div>
</div>
