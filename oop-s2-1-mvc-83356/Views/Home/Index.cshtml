@using oop_s2_1_mvc_83356.ViewModels;
@model HomeViewModel

@{
    ViewData["Title"] = "Welcome to VGC College";
}

<style>
    :root {
        --vgc-primary: #003580;
        --vgc-light: #f8f9fa;
    }

    .hero-section {
        background: linear-gradient(135deg, var(--vgc-primary) 0%, #004fa8 100%);
        color: white;
        padding: 4rem 2rem;
        margin: -1rem 0 3rem 0;
        border-radius: 0;
        box-shadow: 0 4px 10px rgba(0, 53, 128, 0.15);
    }

    .hero-section h1 {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .hero-section p {
        font-size: 1.1rem;
        opacity: 0.98;
        font-weight: 500;
    }

    .stats-card {
        background: white;
        border: none;
        border-radius: 10px;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        height: 100%;
    }

    .stats-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
    }

    .stats-card-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    .stats-card-value {
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--vgc-primary);
        margin: 0.5rem 0;
    }

    .stats-card-label {
        font-size: 0.95rem;
        color: #666;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .feature-card {
        border: none;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        height: 100%;
    }

    .feature-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
    }

    .course-card {
        border: none;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

    .course-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
    }

    .course-card-header {
        background: linear-gradient(135deg, var(--vgc-primary), #004fa8);
        color: white;
        border-radius: 10px 10px 0 0;
        padding: 1.5rem;
    }

    .top-student-rank {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--vgc-primary);
        min-width: 60px;
        text-align: center;
    }

    .top-student-info {
        flex-grow: 1;
    }

    .top-student-name {
        font-weight: 700;
        font-size: 1rem;
        color: #333;
        margin-bottom: 0.3rem;
    }

    .top-student-meta {
        font-size: 0.85rem;
        color: #999;
    }

    .top-student-grade {
        font-size: 1.3rem;
        font-weight: 700;
        color: #28a745;
        text-align: center;
        min-width: 80px;
    }

    .branch-card {
        border: none;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        text-align: center;
    }

    .branch-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
    }

    .branch-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        color: var(--vgc-primary);
    }

    .section-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 2rem;
        color: #333;
        position: relative;
        padding-bottom: 1rem;
    }

    .section-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 60px;
        height: 4px;
        background: var(--vgc-primary);
        border-radius: 2px;
    }

    .btn-primary {
        background: var(--vgc-primary);
        border: none;
    }

    .btn-primary:hover {
        background: #002644;
    }

    .auth-actions {
        margin-top: 2rem;
    }

    .auth-actions .btn {
        padding: 0.75rem 2rem;
        font-weight: 600;
        font-size: 1rem;
    }

    footer {
        background: var(--vgc-primary);
        color: white;
        padding: 2rem 0;
        margin-top: 4rem;
    }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <div class="container-lg">
        @if (!(User.Identity?.IsAuthenticated ?? false))
        {
            <h1 class="mb-3">Welcome to VGC College</h1>
            <p class="lead mb-0">Managing students, courses and academic progress across Ireland</p>
        }
        else
        {
            <h1 class="mb-2">Welcome back! 👋</h1>
            <p class="lead mb-0">@User.Identity?.Name</p>
        }
    </div>
</div>

<div class="container-lg mb-5">
    @if (!(User.Identity?.IsAuthenticated ?? false))
    {
        <!-- SECTION 1: Stats Cards (visible to all) -->
        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-3">
                <div class="stats-card">
                    <div class="stats-card-icon">🎓</div>
                    <div class="stats-card-value">@Model.TotalStudents</div>
                    <div class="stats-card-label">Students</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="stats-card">
                    <div class="stats-card-icon">📚</div>
                    <div class="stats-card-value">@Model.TotalCourses</div>
                    <div class="stats-card-label">Courses</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="stats-card">
                    <div class="stats-card-icon">🏫</div>
                    <div class="stats-card-value">@Model.TotalBranches</div>
                    <div class="stats-card-label">Branches</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="stats-card">
                    <div class="stats-card-icon">👨‍🏫</div>
                    <div class="stats-card-value">@Model.TotalFaculty</div>
                    <div class="stats-card-label">Faculty</div>
                </div>
            </div>
        </div>

        <!-- SECTION 2: Courses Available -->
        <div class="mb-5">
            <h2 class="section-title">Our Courses</h2>
            <div class="row g-4">
                @foreach (var course in Model.RecentCourses)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="course-card h-100">
                            <div class="course-card-header">
                                <h5 class="card-title mb-2">📘 @course.Name</h5>
                                <small class="text-white-50">@course.BranchName</small>
                            </div>
                            <div class="card-body">
                                @if (course.StartDate.HasValue && course.EndDate.HasValue)
                                {
                                    <p class="card-text mb-2">
                                        <i class="bi bi-calendar"></i>
                                        @course.StartDate?.ToString("MMM yyyy") – @course.EndDate?.ToString("MMM yyyy")
                                    </p>
                                }
                                <p class="card-text mb-3">
                                    <i class="bi bi-people"></i>
                                    @course.EnrolledStudentsCount student@(course.EnrolledStudentsCount != 1 ? "s" : "") enrolled
                                </p>
                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    <a href="/Course/@course.Id" class="btn btn-sm btn-primary">View Details →</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- SECTION 3: Branches -->
        <div class="mb-5">
            <h2 class="section-title">Our Campuses</h2>
            <div class="row g-4">
                @foreach (var branch in Model.Branches)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="branch-card p-4">
                            <div class="branch-icon">🏫</div>
                            <h5 class="fw-bold mb-2">@branch.Name</h5>
                            <p class="text-muted mb-3" style="font-size: 0.9rem;">@branch.Address</p>
                            <small class="text-secondary">@branch.CoursesCount course@(branch.CoursesCount != 1 ? "s" : "")</small>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- SECTION 4: Call to Action -->
        <div class="row">
            <div class="col-lg-6 offset-lg-3">
                <div class="card feature-card border-0 shadow-lg" style="background: linear-gradient(135deg, var(--vgc-primary) 0%, #004fa8 100%); color: white;">
                    <div class="card-body text-center p-4">
                        <h4 class="fw-bold mb-3">Ready to Get Started?</h4>
                        <p class="mb-4">Access your account to view courses, track grades, and manage your academic progress.</p>
                        <div class="auth-actions">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-light btn-lg me-2">
                                <i class="bi bi-box-arrow-in-right"></i> Login
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (User.IsInRole("Admin"))
    {
        <!-- ADMIN Dashboard View -->
        <!-- Stats Overview -->
        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-3">
                <div class="stats-card">
                    <div class="stats-card-icon">🎓</div>
                    <div class="stats-card-value">@Model.TotalStudents</div>
                    <div class="stats-card-label">Students</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="stats-card">
                    <div class="stats-card-icon">📚</div>
                    <div class="stats-card-value">@Model.TotalCourses</div>
                    <div class="stats-card-label">Courses</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="stats-card">
                    <div class="stats-card-icon">🏫</div>
                    <div class="stats-card-value">@Model.TotalBranches</div>
                    <div class="stats-card-label">Branches</div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="stats-card">
                    <div class="stats-card-icon">📋</div>
                    <div class="stats-card-value">@Model.TotalEnrolments</div>
                    <div class="stats-card-label">Enrollments</div>
                </div>
            </div>
        </div>

        <!-- Top Students Section -->
        @if (Model.TopStudents.Any())
        {
            <div class="mb-5">
                <h2 class="section-title">Top Performing Students</h2>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead style="background: var(--vgc-light);">
                            <tr>
                                <th style="color: var(--vgc-primary);">Rank</th>
                                <th style="color: var(--vgc-primary);">Student</th>
                                <th style="color: var(--vgc-primary);">Student #</th>
                                <th style="color: var(--vgc-primary);">Avg Grade</th>
                                <th style="color: var(--vgc-primary);">Courses</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.TopStudents.Count; i++)
                            {
                                var student = Model.TopStudents[i];
                                <tr>
                                    <td>
                                        <div class="top-student-rank">
                                            @if (i == 0) { <span>🥇</span> }
                                            else if (i == 1) { <span>🥈</span> }
                                            else if (i == 2) { <span>🥉</span> }
                                        </div>
                                    </td>
                                    <td>
                                        <strong>@student.FirstName @student.LastName</strong>
                                    </td>
                                    <td>@student.StudentNumber</td>
                                    <td>
                                        <span class="badge bg-success" style="font-size: 1rem;">@student.AverageGrade.ToString("F1")%</span>
                                    </td>
                                    <td>@student.CoursesCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Quick Actions -->
        <div class="mb-5">
            <h2 class="section-title">Quick Actions</h2>
            <div class="row g-3">
                <div class="col-md-4 col-lg-3">
                    <a href="/Student/Create" class="btn btn-outline-primary btn-lg w-100 py-3">
                        <i class="bi bi-plus-circle"></i> Add Student
                    </a>
                </div>
                <div class="col-md-4 col-lg-3">
                    <a href="/Course/Create" class="btn btn-outline-primary btn-lg w-100 py-3">
                        <i class="bi bi-plus-circle"></i> Add Course
                    </a>
                </div>
                <div class="col-md-4 col-lg-3">
                    <a href="/Enrolment/Create" class="btn btn-outline-primary btn-lg w-100 py-3">
                        <i class="bi bi-plus-circle"></i> Add Enrollment
                    </a>
                </div>
                <div class="col-md-4 col-lg-3">
                    <a href="/Gradebook/Courses" class="btn btn-outline-primary btn-lg w-100 py-3">
                        <i class="bi bi-graph-up"></i> Gradebook
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<!-- Footer -->
<footer class="mt-5">
    <div class="container-lg py-4 text-center">
        <p class="mb-0">&copy; 2025 Acme Global College (VGC) | Dublin · Cork · Galway</p>
    </div>
</footer>
