@model ErrorViewModel

@{
    ViewData["Title"] = "Access Denied";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="error-page">
                <h1 class="display-1 fw-bold text-warning">403</h1>
                <h2 class="h3 mb-3">Access Denied</h2>
                <p class="text-muted mb-4">
                    You do not have permission to access this resource. If you believe this is an error, please contact an administrator.
                </p>
                <div class="error-icon mb-4">
                    <i class="bi bi-shield-exclamation" style="font-size: 4rem; color: #ffc107;"></i>
                </div>
                <div class="btn-group" role="group">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">
                        <i class="bi bi-house-door"></i> Go Home
                    </a>
                    <button type="button" class="btn btn-secondary btn-lg" onclick="history.back()">
                        <i class="bi bi-arrow-left"></i> Go Back
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .error-page {
        padding: 3rem 0;
    }
</style>
