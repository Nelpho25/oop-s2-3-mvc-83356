@model ErrorViewModel

@{
    ViewData["Title"] = "Server Error";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="error-page">
                <h1 class="display-1 fw-bold text-danger">500</h1>
                <h2 class="h3 mb-3">Internal Server Error</h2>
                <p class="text-muted mb-4">
                    An unexpected error occurred while processing your request. Our team has been notified and will investigate the issue.
                </p>
                <div class="error-icon mb-4">
                    <i class="bi bi-exclamation-circle" style="font-size: 4rem; color: #dc3545;"></i>
                </div>
                <div class="btn-group" role="group">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">
                        <i class="bi bi-house-door"></i> Go Home
                    </a>
                    <button type="button" class="btn btn-secondary btn-lg" onclick="history.back()">
                        <i class="bi bi-arrow-left"></i> Go Back
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .error-page {
        padding: 3rem 0;
    }
</style>
