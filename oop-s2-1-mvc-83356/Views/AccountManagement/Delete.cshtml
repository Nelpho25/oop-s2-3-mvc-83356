@model DeleteUserViewModel

@{
    ViewData["Title"] = "Delete User Account";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="h3 text-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Account
            </h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card border-danger shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Confirm Account Deletion</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        <strong>Warning:</strong> This action cannot be undone. All user data will be permanently deleted.
                    </div>

                    <div class="card bg-light mb-3">
                        <div class="card-body">
                            <p class="mb-2">
                                <strong>Email:</strong><br>
                                <code>@Model.Email</code>
                            </p>
                            <p class="mb-2">
                                <strong>Display Name:</strong><br>
                                @Model.DisplayName
                            </p>
                            <p class="mb-0">
                                <strong>Current Role:</strong><br>
                                <span class="badge bg-@GetRoleBadgeColor(Model.UserRole)">@Model.UserRole</span>
                            </p>
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <h5 class="alert-heading">
                            <i class="bi bi-info-circle me-2"></i>Data That Will Be Deleted
                        </h5>
                        <ul class="mb-0">
                            <li>User account and credentials</li>
                            <li>Role assignments</li>
                            <li>Associated profile (Student/Faculty/Admin)</li>
                            <li>All personal information linked to this account</li>
                        </ul>
                    </div>

                    <form method="post" asp-action="DeleteConfirmed" asp-route-id="@Model.Id">
                        @Html.AntiForgeryToken()

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="confirmDelete" required>
                            <label class="form-check-label" for="confirmDelete">
                                I understand this action cannot be reversed and I want to delete this account
                            </label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger" id="deleteBtn" disabled>
                                <i class="bi bi-trash me-2"></i>Delete Account
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-question-circle me-2"></i>Need Help?
                    </h5>
                </div>
                <div class="card-body">
                    <p class="small">
                        Before deleting this account, consider:
                    </p>
                    <ul class="small">
                        <li>Is this the only administrator account?</li>
                        <li>Are there important records to preserve?</li>
                        <li>Should you lock the account instead?</li>
                    </ul>
                    <p class="small mt-3">
                        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-sm btn-outline-primary w-100">
                            Lock Account Instead
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('confirmDelete').addEventListener('change', function () {
            document.getElementById('deleteBtn').disabled = !this.checked;
        });
    </script>
}

@functions {
    string GetRoleBadgeColor(string role)
    {
        return role switch
        {
            "Admin" => "danger",
            "Faculty" => "info",
            "Student" => "primary",
            _ => "secondary"
        };
    }
}
