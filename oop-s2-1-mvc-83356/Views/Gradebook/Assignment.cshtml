@model Assignment
@{
    ViewData["Title"] = "Assignment Grades - " + Model.Title;
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">@Model.Title</h1>
            <p class="text-muted">@Model.Course?.Name</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Course" asp-route-courseId="@Model.CourseId" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Assignment Details</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Title:</strong></p>
                            <p>@Model.Title</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Due Date:</strong> @(Model.DueDate?.ToString("MMM dd, yyyy") ?? "N/A")</p>
                            <p><strong>Max Score:</strong> @Model.MaxScore</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            @if (!Model.AssignmentResults.Any())
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i> No submissions yet.
                </div>
            }
            else
            {
                <div class="card">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Student</th>
                                    <th class="text-center">Score</th>
                                    <th class="text-center">Percentage</th>
                                    <th>Feedback</th>
                                    <th class="text-center" style="width: 120px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in Model.AssignmentResults.OrderBy(ar => ar.StudentProfile.LastName).ThenBy(ar => ar.StudentProfile.FirstName))
                                {
                                    <tr>
                                        <td>
                                            <strong>@result.StudentProfile?.FirstName @result.StudentProfile?.LastName</strong>
                                            <br />
                                            <small class="text-muted">@result.StudentProfile?.StudentNumber</small>
                                        </td>
                                        <td class="text-center">
                                            @if (result.Score.HasValue)
                                            {
                                                <strong>@result.Score.Value.ToString("F1") / @Model.MaxScore</strong>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not graded</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (result.Score.HasValue)
                                            {
                                                var percentage = (result.Score.Value / Model.MaxScore) * 100;
                                                <span class="badge @(percentage >= 80 ? "bg-success" : percentage >= 70 ? "bg-warning" : "bg-danger")">
                                                    @percentage.ToString("F0")%
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">N/A</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(result.Feedback))
                                            {
                                                <small>@result.Feedback</small>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No feedback</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#editModal_@result.Id" title="Edit Grade">
                                                <i class="bi bi-pencil"></i> Grade
                                            </button>
                                        </td>
                                    </tr>

                                    <!-- Modal for editing score -->
                                    <div class="modal fade" id="editModal_@result.Id" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Grade Assignment</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form method="post" action="@Url.Action("UpdateScore", "Gradebook", new { resultId = result.Id })">
                                                    @Html.AntiForgeryToken()
                                                    <div class="modal-body">
                                                        <p><strong>Student:</strong> @result.StudentProfile?.FirstName @result.StudentProfile?.LastName</p>
                                                        <div class="mb-3">
                                                            <label for="score_@result.Id" class="form-label">Score (out of @Model.MaxScore)</label>
                                                            <input type="number" id="score_@result.Id" name="score" class="form-control" value="@result.Score" step="0.1" min="0" max="@Model.MaxScore" required>
                                                        </div>
                                                        <div class="mb-3">
                                                            <label for="feedback_@result.Id" class="form-label">Feedback</label>
                                                            <textarea id="feedback_@result.Id" name="feedback" class="form-control" rows="3">@result.Feedback</textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-primary">Save Grade</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
