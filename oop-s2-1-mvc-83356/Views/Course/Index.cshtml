@model List<CourseIndexViewModel>

@{
    ViewData["Title"] = "Courses Management";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1 class="h3 mb-0">
                <i class="fas fa-book"></i> Courses
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="@Url.Action("Create", "Course")" class="btn btn-primary">
                <i class="fas fa-plus"></i> New Course
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No courses found. <a href="@Url.Action("Create", "Course")" class="alert-link">Create one</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course Name</th>
                            <th>Branch</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th class="text-center">Enrolled</th>
                            <th class="text-center" style="width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model.OrderBy(c => c.StartDate))
                        {
                            <tr>
                                <td>
                                    <strong>@course.Name</strong>
                                </td>
                                <td>@course.BranchName</td>
                                <td>@(course.StartDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                <td>@(course.EndDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                <td class="text-center">
                                    <span class="badge bg-success">@course.EnrolledCount</span>
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Details", "Course", new { id = course.Id })" class="btn btn-sm btn-info" title="View Course Details">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                    <a href="@Url.Action("Edit", "Course", new { id = course.Id })" class="btn btn-sm btn-warning" title="Edit Course">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <a href="@Url.Action("Delete", "Course", new { id = course.Id })" class="btn btn-sm btn-danger" title="Delete Course">
                                        <i class="fas fa-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
