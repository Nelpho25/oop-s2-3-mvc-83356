@model List<EnrolmentIndexViewModel>

@{
    ViewData["Title"] = "Enrolments Management";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1 class="h3 mb-0">
                <i class="fas fa-clipboard-check"></i> Enrolments
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="@Url.Action("Create", "Enrolment")" class="btn btn-primary">
                <i class="fas fa-plus"></i> New Enrolment
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No enrolments found. <a href="@Url.Action("Create", "Enrolment")" class="alert-link">Create one</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Student</th>
                            <th>Course</th>
                            <th>Status</th>
                            <th>Enrolment Date</th>
                            <th class="text-center" style="width: 100px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var enrol in Model.OrderByDescending(e => e.EnrolmentDate))
                        {
                            <tr>
                                <td>
                                    <strong>@enrol.StudentName</strong><br>
                                    <small class="text-muted"><code>@enrol.StudentNumber</code></small>
                                </td>
                                <td>@enrol.CourseName</td>
                                <td>
                                    @switch (enrol.Status)
                                    {
                                        case "Active":
                                            <span class="badge bg-success">Active</span>
                                            break;
                                        case "Withdrawn":
                                            <span class="badge bg-warning">Withdrawn</span>
                                            break;
                                        case "Completed":
                                            <span class="badge bg-info">Completed</span>
                                            break;
                                    }
                                </td>
                                <td>@enrol.EnrolmentDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-center">
                                    <a href="@Url.Action("Edit", "Enrolment", new { id = enrol.Id })" class="btn btn-sm btn-warning" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", "Enrolment", new { id = enrol.Id })" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
