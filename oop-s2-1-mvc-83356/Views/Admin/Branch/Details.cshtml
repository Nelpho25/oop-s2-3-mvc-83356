@model BranchDetailsViewModel

@{
    ViewData["Title"] = $"Branch: {Model.Name}";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3">
                <i class="fas fa-code-branch"></i> @Model.Name
            </h1>
            <p class="text-muted">@Model.Address</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Edit", "Branch", new { id = Model.Id })" class="btn btn-warning">
                <i class="fas fa-edit"></i> Edit
            </a>
            <a href="@Url.Action("Delete", "Branch", new { id = Model.Id })" class="btn btn-danger">
                <i class="fas fa-trash"></i> Delete
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="fas fa-book"></i> Courses
                <span class="badge bg-secondary float-end">@Model.Courses.Count</span>
            </h5>
        </div>
        <div class="table-responsive">
            @if (Model.Courses.Count == 0)
            {
                <div class="alert alert-info m-3 mb-0" role="alert">
                    No courses assigned to this branch.
                </div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course Name</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model.Courses.OrderBy(c => c.StartDate))
                        {
                            <tr>
                                <td>@course.Name</td>
                                <td>@(course.StartDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                <td>@(course.EndDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                <td class="text-center">
                                    <a href="@Url.Action("Details", "Course", new { id = course.Id })" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Index", "Branch")" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Branches
        </a>
    </div>
</div>
