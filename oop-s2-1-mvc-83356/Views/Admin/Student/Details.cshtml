@model StudentDetailsViewModel

@{
    ViewData["Title"] = $"Student: {Model.FullName}";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3">
                <i class="fas fa-graduation-cap"></i> @Model.FullName
            </h1>
            <p class="text-muted"><code>@Model.StudentNumber</code> | @Model.Email</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Edit", "Student", new { id = Model.Id })" class="btn btn-warning">
                <i class="fas fa-edit"></i> Edit
            </a>
            <a href="@Url.Action("Delete", "Student", new { id = Model.Id })" class="btn btn-danger">
                <i class="fas fa-trash"></i> Delete
            </a>
        </div>
    </div>

    <!-- Student Info Card -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-user"></i> Profile Information</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Phone:</strong> @(string.IsNullOrEmpty(Model.Phone) ? "N/A" : Model.Phone)</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Address:</strong> @(string.IsNullOrEmpty(Model.Address) ? "N/A" : Model.Address)</p>
                    <p><strong>Date of Birth:</strong> @Model.DateOfBirth.ToString("MMM dd, yyyy")</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs for different sections -->
    <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="enrolments-tab" data-bs-toggle="tab" data-bs-target="#enrolments" type="button" role="tab" aria-controls="enrolments" aria-selected="true">
                <i class="fas fa-book"></i> Enrolments (@Model.Enrolments.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="assignments-tab" data-bs-toggle="tab" data-bs-target="#assignments" type="button" role="tab" aria-controls="assignments" aria-selected="false">
                <i class="fas fa-tasks"></i> Assignments (@Model.AssignmentResults.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="exams-tab" data-bs-toggle="tab" data-bs-target="#exams" type="button" role="tab" aria-controls="exams" aria-selected="false">
                <i class="fas fa-file-alt"></i> Exams (@Model.ExamResults.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="attendance-tab" data-bs-toggle="tab" data-bs-target="#attendance" type="button" role="tab" aria-controls="attendance" aria-selected="false">
                <i class="fas fa-calendar"></i> Attendance (@Model.AttendanceHistory.Count)
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content">
        <!-- Enrolments Tab -->
        <div class="tab-pane fade show active" id="enrolments" role="tabpanel" aria-labelledby="enrolments-tab">
            <div class="card">
                <div class="table-responsive">
                    @if (Model.Enrolments.Count == 0)
                    {
                        <div class="alert alert-info m-3 mb-0" role="alert">
                            No enrolments found.
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Course</th>
                                    <th>Status</th>
                                    <th>Enrolment Date</th>
                                    <th>Completion Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var enrol in Model.Enrolments.OrderByDescending(e => e.EnrolmentDate))
                                {
                                    <tr>
                                        <td><strong>@enrol.CourseName</strong></td>
                                        <td>
                                            @switch (enrol.Status)
                                            {
                                                case "Active":
                                                    <span class="badge bg-success">Active</span>
                                                    break;
                                                case "Withdrawn":
                                                    <span class="badge bg-warning">Withdrawn</span>
                                                    break;
                                                case "Completed":
                                                    <span class="badge bg-info">Completed</span>
                                                    break;
                                            }
                                        </td>
                                        <td>@enrol.EnrolmentDate.ToString("MMM dd, yyyy")</td>
                                        <td>@(enrol.CompletionDate.HasValue ? enrol.CompletionDate.Value.ToString("MMM dd, yyyy") : "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <!-- Assignments Tab -->
        <div class="tab-pane fade" id="assignments" role="tabpanel" aria-labelledby="assignments-tab">
            <div class="card">
                <div class="table-responsive">
                    @if (Model.AssignmentResults.Count == 0)
                    {
                        <div class="alert alert-info m-3 mb-0" role="alert">
                            No assignment results found.
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Course</th>
                                    <th>Assignment</th>
                                    <th class="text-center">Score</th>
                                    <th class="text-center">Percentage</th>
                                    <th>Feedback</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in Model.AssignmentResults.OrderByDescending(r => r.SubmissionDate))
                                {
                                    <tr>
                                        <td>@result.CourseName</td>
                                        <td>@result.AssignmentName</td>
                                        <td class="text-center">
                                            <strong>@result.Score/@result.MaxScore</strong>
                                        </td>
                                        <td class="text-center">
                                            @{
                                                var percentage = result.Percentage;
                                                string badge = percentage >= 80 ? "success" : percentage >= 60 ? "warning" : "danger";
                                            }
                                            <span class="badge bg-@badge">@percentage.ToString("F1")%</span>
                                        </td>
                                        <td class="text-muted small">@(string.IsNullOrEmpty(result.Feedback) ? "-" : result.Feedback)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <!-- Exams Tab -->
        <div class="tab-pane fade" id="exams" role="tabpanel" aria-labelledby="exams-tab">
            <div class="card">
                <div class="table-responsive">
                    @if (Model.ExamResults.Count == 0)
                    {
                        <div class="alert alert-info m-3 mb-0" role="alert">
                            No exam results found.
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Course</th>
                                    <th>Exam</th>
                                    <th class="text-center">Score</th>
                                    <th class="text-center">Grade</th>
                                    <th>Released</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in Model.ExamResults.OrderByDescending(r => r.ExamDate))
                                {
                                    <tr>
                                        <td>@result.CourseName</td>
                                        <td>@result.ExamName</td>
                                        <td class="text-center">@result.Score/@result.MaxScore</td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">@result.Grade</span>
                                        </td>
                                        <td>
                                            @if (result.ResultsReleased)
                                            {
                                                <span class="badge bg-success"><i class="fas fa-check"></i></span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger"><i class="fas fa-lock"></i></span>
                                            }
                                        </td>
                                        <td>@result.ExamDate.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <!-- Attendance Tab -->
        <div class="tab-pane fade" id="attendance" role="tabpanel" aria-labelledby="attendance-tab">
            @if (Model.AttendanceHistory.Count == 0)
            {
                <div class="alert alert-info" role="alert">
                    No attendance records found.
                </div>
            }
            else
            {
                @foreach (var course in Model.AttendanceHistory)
                {
                    <div class="card mb-3">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">@course.CourseName</h6>
                            <div>
                                <strong>@course.PresentCount/@course.TotalSessions</strong> Present
                                <span class="badge @(course.AttendanceRate >= 75 ? "bg-success" : "bg-warning")">
                                    @course.AttendanceRate.ToString("F1")%
                                </span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                @foreach (var record in course.Records.OrderBy(r => r.SessionDate))
                                {
                                    <div class="col-md-3 col-sm-4 col-6 mb-2">
                                        <small class="d-block text-muted">@record.SessionDate.ToString("MMM dd")</small>
                                        @if (record.IsPresent)
                                        {
                                            <span class="badge bg-success">Present</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Absent</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Index", "Student")" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Students
        </a>
    </div>
</div>
