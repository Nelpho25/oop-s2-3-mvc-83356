@model List<ExamIndexViewModel>

@{
    ViewData["Title"] = "Exam Results Management";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1 class="h3 mb-0">
                <i class="fas fa-file-alt"></i> Exams & Results
            </h1>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No exams found.
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Course</th>
                            <th>Exam Name</th>
                            <th>Date</th>
                            <th class="text-center">Submissions</th>
                            <th class="text-center">Results Released</th>
                            <th class="text-center" style="width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exam in Model.OrderByDescending(e => e.ExamDate))
                        {
                            <tr>
                                <td>@exam.CourseName</td>
                                <td><strong>@exam.ExamName</strong></td>
                                <td>@exam.ExamDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-center">
                                    <span class="badge bg-info">@exam.SubmissionsCount</span>
                                </td>
                                <td class="text-center">
                                    <form method="post" action="@Url.Action("ToggleResultsRelease", "Exam", new { id = exam.Id })" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(exam.ResultsReleased ? "btn-success" : "btn-secondary")" title="Toggle result release">
                                            @if (exam.ResultsReleased)
                                            {
                                                <text><i class="fas fa-eye"></i> Released</text>
                                            }
                                            else
                                            {
                                                <text><i class="fas fa-eye-slash"></i> Hidden</text>
                                            }
                                        </button>
                                    </form>
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Results", "Exam", new { id = exam.Id })" class="btn btn-sm btn-info" title="View Exam Results">
                                        <i class="fas fa-eye"></i> Results
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
