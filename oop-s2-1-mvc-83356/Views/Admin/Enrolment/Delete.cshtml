@model EnrolmentIndexViewModel

@{
    ViewData["Title"] = "Delete Enrolment";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Confirm Delete
                    </h5>
                </div>
                <div class="card-body">
                    <p class="mb-3">
                        Are you sure you want to delete the enrolment for <strong>@Model.StudentName</strong> in <strong>@Model.CourseName</strong>?
                    </p>
                    <p class="text-muted">
                        This action cannot be undone.
                    </p>

                    <form method="post" action="@Url.Action("DeleteConfirmed", "Enrolment", new { id = Model.Id })">
                        @Html.AntiForgeryToken()

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Delete Enrolment
                            </button>
                            <a href="@Url.Action("Index", "Enrolment")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
