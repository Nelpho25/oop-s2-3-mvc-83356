@model List<BranchIndexViewModel>

@{
    ViewData["Title"] = "Branches Management";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1 class="h3 mb-0">
                <i class="fas fa-code-branch"></i> Branches
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <a href="@Url.Action("Create", "Branch")" class="btn btn-primary">
                <i class="fas fa-plus"></i> New Branch
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No branches found. <a href="@Url.Action("Create", "Branch")" class="alert-link">Create one</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Address</th>
                            <th>Courses</th>
                            <th class="text-center" style="width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var branch in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@branch.Name</strong>
                                </td>
                                <td>@branch.Address</td>
                                <td>
                                    <span class="badge bg-info">@branch.CourseCount</span>
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Details", "Branch", new { id = branch.Id })" class="btn btn-sm btn-info" title="View Details">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                    <a href="@Url.Action("Edit", "Branch", new { id = branch.Id })" class="btn btn-sm btn-warning" title="Edit Branch">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <a href="@Url.Action("Delete", "Branch", new { id = branch.Id })" class="btn btn-sm btn-danger" title="Delete Branch">
                                        <i class="fas fa-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
